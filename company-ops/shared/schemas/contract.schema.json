{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://company-ops.local/schemas/contract.schema.json",
  "title": "CONTRACT Schema",
  "description": "Schema for subsystem interaction contracts (CONTRACT.yaml)",
  "type": "object",

  "required": [
    "version",
    "subsystem_id",
    "provides"
  ],

  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },

    "subsystem_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },

    "last_updated": {
      "type": "string",
      "format": "date"
    },

    "provides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["service_id", "name", "version"],
        "properties": {
          "service_id": {
            "type": "string",
            "pattern": "^SVC-\\d{3}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "input_schema": {
            "type": "object",
            "description": "JSON Schema for input validation"
          },
          "output_schema": {
            "type": "object",
            "description": "JSON Schema for output validation"
          },
          "sla": {
            "type": "object",
            "properties": {
              "response_time_minutes": {
                "type": "integer",
                "minimum": 1
              },
              "availability": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "error_rate_max": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["subsystem"],
              "properties": {
                "subsystem": {
                  "type": "string"
                },
                "service": {
                  "type": "string"
                },
                "need": {
                  "type": "string"
                },
                "required": {
                  "type": "boolean",
                  "default": true
                }
              }
            }
          }
        }
      }
    },

    "consumes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["service_id", "provider"],
        "properties": {
          "service_id": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "version_constraint": {
            "type": "string",
            "description": "SemVer constraint like >=1.0.0 or ^1.2.3"
          },
          "frequency": {
            "type": "string",
            "enum": ["on-demand", "hourly", "daily", "real-time", "weekly"]
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },

    "events": {
      "type": "object",
      "properties": {
        "subscribes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["event", "action"],
            "properties": {
              "event": {
                "type": "string",
                "description": "Event pattern like subsystem.event-type"
              },
              "action": {
                "type": "string",
                "description": "Action to take when event occurs"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "publishes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["event"],
            "properties": {
              "event": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "payload": {
                "type": "object",
                "description": "Schema of the event payload"
              }
            }
          }
        }
      }
    },

    "data_sharing": {
      "type": "object",
      "properties": {
        "provides_data": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "format": {
                "type": "string",
                "enum": ["json", "yaml", "markdown", "binary", "csv"]
              },
              "access_level": {
                "type": "string",
                "enum": ["public", "internal", "restricted", "confidential"]
              },
              "update_frequency": {
                "type": "string",
                "enum": ["on-change", "real-time", "hourly", "daily", "weekly"]
              }
            }
          }
        },
        "requires_data": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "provider"],
            "properties": {
              "name": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              },
              "purpose": {
                "type": "string"
              },
              "access_level_needed": {
                "type": "string"
              }
            }
          }
        }
      }
    },

    "quality": {
      "type": "object",
      "properties": {
        "response_time": {
          "type": "object",
          "properties": {
            "urgent": {
              "type": "string"
            },
            "normal": {
              "type": "string"
            },
            "low": {
              "type": "string"
            }
          }
        },
        "error_handling": {
          "type": "object",
          "properties": {
            "retry_count": {
              "type": "integer"
            },
            "retry_delay_seconds": {
              "type": "integer"
            },
            "escalation_after_failures": {
              "type": "integer"
            }
          }
        }
      }
    },

    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date", "changes"],
        "properties": {
          "version": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "author": {
            "type": "string"
          },
          "changes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": ["active", "deprecated", "planned"]
          }
        }
      }
    }
  }
}
