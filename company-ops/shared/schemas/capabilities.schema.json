{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://company-ops.local/schemas/capabilities.schema.json",
  "title": "CAPABILITIES Schema",
  "description": "Schema for subsystem capabilities definition (CAPABILITIES.yaml)",
  "type": "object",

  "required": [
    "version",
    "subsystem_id",
    "capabilities"
  ],

  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },

    "subsystem_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },

    "last_updated": {
      "type": "string",
      "format": "date"
    },

    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CAP-\\d{3}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },

          "skills": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of skills required for this capability"
          },

          "tools": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": ["ai", "software", "service", "library"]
                },
                "usage": {
                  "type": "string"
                }
              }
            }
          },

          "inputs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "required": {
                  "type": "boolean",
                  "default": true
                },
                "description": {
                  "type": "string"
                },
                "default": {}
              }
            }
          },

          "outputs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          },

          "quality_metrics": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "target"],
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": ["percentage", "time", "count", "score"]
                },
                "target": {
                  "type": "string",
                  "description": "Target value like >=80% or <30m"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          },

          "preconditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },

          "postconditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },

          "documentation": {
            "type": "string",
            "description": "Path to detailed documentation"
          },

          "status": {
            "type": "string",
            "enum": ["planned", "active", "deprecated"],
            "default": "planned"
          }
        }
      }
    },

    "maturity_levels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "name", "description"],
        "properties": {
          "level": {
            "type": "integer",
            "minimum": 1
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },

    "current_maturity": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      },
      "description": "Current maturity level for each capability (0 = not implemented)"
    },

    "development_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capability_id", "current_level", "target_level"],
        "properties": {
          "capability_id": {
            "type": "string"
          },
          "current_level": {
            "type": "integer"
          },
          "target_level": {
            "type": "integer"
          },
          "timeline": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },

    "usage_statistics": {
      "type": "object",
      "properties": {
        "period": {
          "type": "string"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "invocations": {
                "type": "integer"
              },
              "success_rate": {
                "type": "number"
              },
              "avg_duration_minutes": {
                "type": "number"
              }
            }
          }
        }
      }
    }
  }
}
